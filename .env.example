# Instance identity
INSTANCE_ROLE=                   # production | development
TOWER_HOST=                      # Tailscale IP of Tower (100.106.80.49)

# Soul documents — local directory outside the repo
# Contains: SOUL.md, MEMORY.md, AGENTS.md, HEARTBEAT.md, AGENT_CONTRACT.md, memory/
# Deployed out-of-band via Tailscale/RDP. Never in the public repo.
SOUL_PATH=                       # e.g. C:\DuggerBot-Soul or /opt/duggerbot-soul

# Provider credentials
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Ollama
OLLAMA_HOST=                     # http://localhost:11434
OLLAMA_MODEL=                    # phi3.5:3.8b | qwen2.5:3b

# Database
DB_PATH=                         # Path to SQLite usage ledger. Default: duggerbot.db in repo root

# MCP Server
MCP_PORT=8001
MCP_AUTH_TOKEN=                  # Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# Agent authentication
DEVIN_AUTH_TOKEN=                # Auth token for Devin MCP access. Leave blank to disable.

# Twin protocol
PRESENCE_PORT=8002
DELEGATION_TIMEOUT_SECONDS=5     # Max wait for Remote TOBOR task delegation response
STATE_REQUEST_TIMEOUT_SECONDS=2  # Max wait for Tower usage state before routing blind

# Telegram
TELEGRAM_BOT_TOKEN=              # Same token as PrivyBot — same bot, same channel
TELEGRAM_CHAT_ID=                # Same chat ID as PrivyBot

# Self-update
UPDATE_CHECK_INTERVAL_MINUTES=60   # How often to check for updates (background)
UPDATE_CHECK_RETRY_MINUTES=5       # Retry delay when deferred due to in-flight work

# Budget
CLAUDE_DAILY_CAP_USD=0.25
